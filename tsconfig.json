{
  "extends": "@gilbarbara/tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    "downlevelIteration": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext",
      "webworker"
    ],
    "module": "ESNext",
    "noEmit": true,
    "paths": {
      "~/*": ["app/*"]
    },
    "plugins": [{ "name": "next" }],
    "incremental": true,
    "isolatedModules": true
  },
  "include": ["app/**/*", "src/**/*"],
  "exclude": ["node_modules"]
}
